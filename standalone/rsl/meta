 * @param macro function-like macro applied to every element
 * @param ... elements to loop over
*/
#define $for_each(macro, ...) RSL_IMPL_FOR_EACH_DELIM(macro, RSL_IMPL_DELIM_NONE, __VA_ARGS__)

